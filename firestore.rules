rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // AUTHENTIFICATION
    // ============================================
    function isAuthenticated() {
      return request.auth != null;
    }

    // ============================================
    // TEAM - Membres de l'équipe 
    // ============================================
    match /team/{memberId} {
      allow read: if true;  // Public read
      allow create, update, delete: if true;  // Ouvert en dev (à sécuriser en prod)
    }

    // ============================================
    // PLAN - Plan de conformité principal
    // ============================================
    match /plan/{document=**} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // WORKFLOWS - Diagrammes Mermaid et workflows
    // ============================================
    match /workflows/{workflowId} {
      allow read, write: if true;  // Ouvert en dev
      
      match /versions/{versionId} {
        allow read, write: if true;
      }
    }

    // ============================================
    // DOCUMENTS - Gestion documentaire
    // ============================================
    match /documents/{docId} {
      allow read, write: if true;  // Ouvert en dev
      
      match /versions/{versionId} {
        allow read, write: if true;
      }
    }

    // ============================================
    // RISK-MAPPING - Cartographie des risques
    // ============================================
    match /riskMapping/{riskId} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // NEWS - Actualités et veille réglementaire
    // ============================================
    match /news/{newsId} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // KEYWORDS - Mots-clés de recherche
    // ============================================
    match /keywords/{keywordId} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // REGULATIONS - Réglementations identifiées
    // ============================================
    match /identifiedRegulations/{regId} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // OTHER COLLECTIONS (Training, Users, etc)
    // ============================================
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    match /trainingRegistry/{document=**} {
      allow read, write: if true;
    }
    match /sensitizationCampaigns/{document=**} {
      allow read, write: if true;
    }
    match /upcomingSessions/{document=**} {
      allow read, write: if true;
    }
    match /documentData/{document=**} {
      allow read, write: if true;
    }
    match /riskMappingMeta/{document=**} {
       allow read, write: if true;
    }

    match /tasks/{document=**} {
      allow read, write: if true;
    }
    match /available_users/{document=**} {
      allow read, write: if true;
    }
    match /available_roles/{document=**} {
      allow read, write: if true;
    }

    // ============================================
    // TIMELINE - Événements de la timeline
    // ============================================
    match /timeline/{eventId} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // ECOSYSTEMS - Écosystèmes
    // ============================================
    match /ecosystems/{document=**} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // AUDIT LOGS - Logs des actions
    // ============================================
    match /audit_logs/{logId} {
      allow read, write: if true;
    }
    match /activity_logs/{logId} {
      allow read, write: if true;
    }

    // ============================================
    // CONFIG & SETTINGS - Configuration de l'application
    // ============================================
    match /config/{document=**} {
      allow read, write: if true;  // Ouvert en dev
    }
    match /settings/{document=**} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // QUICK-RESPONSE - Historique des décisions
    // ============================================
    match /quickResponseHistory/{decisionId} {
      allow read, write: if true;  // Ouvert en dev
    }

    // ============================================
    // REGTOOLS HISTORY - Historique des rapprochements
    // ============================================
    match /regtoolsHistory/{document=**} {
      allow read, write: if true;
    }

    // ============================================
    // CONTROLE ET SUIVI - Checklists de contrôle
    // ============================================
    match /controleSuivi/{document=**} {
      allow read, write: if true;
    }
    // ============================================
    // RISK FACTOR LOGS - Journal des mises à jour de la matrice des risques
    // ============================================
    match /riskFactorLogs/{logId} {
      allow read, write: if true;  // Collaboratif — tous les utilisateurs authentifiés
    }
    // ============================================
    // MATRIX CONFIG - Facteurs KYC collaboratifs
    // ============================================
    match /matrixConfig/{document=**} {
      allow read, write: if true;  // Collaboratif — synchronisé pour tous les utilisateurs
    }
  }
}
